# This file is a Go template processed by `databricks apps init --template <path>`.
# Template variables are substituted and the result is written as .env.
{{- if ne .profile ""}}
DATABRICKS_CONFIG_PROFILE={{.profile}}
{{- else}}
DATABRICKS_HOST={{.workspaceHost}}
{{- end}}
{{- if .dotEnv.content}}
{{.dotEnv.content}}
{{- end}}
DATABRICKS_APP_PORT=8000
DATABRICKS_APP_NAME={{.projectName}}

# RAG-specific configuration (not managed by an AppKit plugin).
# DATABRICKS_WORKSPACE_ID is the NUMERIC workspace id used to construct the
# AI Gateway base URL (https://<id>.ai-gateway.cloud.databricks.com). Find it with:
#   databricks api get /api/2.1/unity-catalog/current-metastore-assignment \
#     | python3 -c "import json,sys;print(json.load(sys.stdin)['workspace_id'])"
# (Not to be confused with the URL slug https://dbc-XXXXXXXX-YYYY.cloud.databricks.com.)
DATABRICKS_WORKSPACE_ID=

# Override to use a different chat completion endpoint.
DATABRICKS_ENDPOINT=databricks-gpt-5-4-mini

# Override to use a different embeddings endpoint.
DATABRICKS_EMBEDDING_ENDPOINT=databricks-gte-large-en

# Set to "true" to force re-seeding the rag.documents table on restart.
RAG_RESEED=false
