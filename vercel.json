{
  "devCommand": "docusaurus start --port $PORT --no-open",
  "functions": {
    "api/mcp.ts": {
      "includeFiles": "docs/**",
      "maxDuration": 30
    },
    "api/markdown.ts": {
      "includeFiles": "{docs/**,content/about-devhub.md,content/solutions/**,content/recipes/**/*.md,content/examples/**/*.md}",
      "maxDuration": 30
    },
    "api/bootstrap-prompt.ts": {
      "includeFiles": "{content/about-devhub.md,content/recipes/**/*.md}",
      "maxDuration": 10
    },
    "api/llms.ts": {
      "includeFiles": "docs/**",
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/devhub",
      "destination": "/"
    },
    {
      "source": "/devhub/",
      "destination": "/"
    },
    {
      "source": "/devhub/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/devhub/docs/llms.txt",
      "destination": "/api/llms"
    },
    {
      "source": "/devhub/llms.txt",
      "destination": "/api/llms"
    },
    {
      "source": "/devhub/docs/(.+)\\.md",
      "destination": "/api/markdown?section=docs&slug=$1"
    },
    {
      "source": "/devhub/templates.md",
      "destination": "/api/markdown?section=templates&slug="
    },
    {
      "source": "/devhub/solutions.md",
      "destination": "/api/markdown?section=solutions&slug="
    },
    {
      "source": "/devhub/solutions/(.+)\\.md",
      "destination": "/api/markdown?section=solutions&slug=$1"
    },
    {
      "source": "/devhub/templates/(.+)\\.md",
      "destination": "/api/markdown?section=templates&slug=$1"
    },
    {
      "source": "/devhub/(.+)\\.md",
      "destination": "/api/markdown?section=docs&slug=$1"
    },
    {
      "source": "/devhub/docs/(.*)",
      "destination": "/docs/$1"
    },
    {
      "source": "/devhub/templates/(.*)",
      "destination": "/templates/$1"
    },
    {
      "source": "/devhub/solutions/(.*)",
      "destination": "/solutions/$1"
    },
    {
      "source": "/devhub/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/devhub/img/(.*)",
      "destination": "/img/$1"
    },
    {
      "source": "/devhub/appkit-preview/(.*)",
      "destination": "/appkit-preview/$1"
    },
    {
      "source": "/devhub/raw-docs/(.*)",
      "destination": "/raw-docs/$1"
    },
    {
      "source": "/devhub/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/devhub/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/devhub/search-doc(.*).json",
      "destination": "/search-doc$1.json"
    },
    {
      "source": "/devhub/lunr-index(.*).json",
      "destination": "/lunr-index$1.json"
    },
    {
      "source": "/docs/llms.txt",
      "destination": "/llms.txt"
    },
    {
      "source": "/docs/(.+)\\.md",
      "destination": "/api/markdown?section=docs&slug=$1"
    },
    {
      "source": "/templates.md",
      "destination": "/api/markdown?section=templates&slug="
    },
    {
      "source": "/solutions.md",
      "destination": "/api/markdown?section=solutions&slug="
    },
    {
      "source": "/solutions/(.+)\\.md",
      "destination": "/api/markdown?section=solutions&slug=$1"
    },
    {
      "source": "/templates/(.+)\\.md",
      "destination": "/api/markdown?section=templates&slug=$1"
    },
    {
      "source": "/(.+)\\.md",
      "destination": "/api/markdown?section=docs&slug=$1"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    },
    {
      "source": "/devhub/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
