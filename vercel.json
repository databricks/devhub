{
  "devCommand": "docusaurus start --port $PORT --no-open",
  "functions": {
    "api/mcp.ts": {
      "includeFiles": "docs/**",
      "maxDuration": 30
    },
    "api/markdown.ts": {
      "includeFiles": "{docs/**,content/about-devhub.md,content/solutions/**,content/recipes/**/*.md,content/examples/**/*.md}",
      "maxDuration": 30
    },
    "api/bootstrap-prompt.ts": {
      "includeFiles": "{content/about-devhub.md,content/recipes/**/*.md}",
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/docs/llms.txt",
      "destination": "/llms.txt"
    },
    {
      "source": "/docs/(.+)\\.md",
      "destination": "/api/markdown?section=docs&slug=$1"
    },
    {
      "source": "/templates.md",
      "destination": "/api/markdown?section=resources&slug="
    },
    {
      "source": "/solutions.md",
      "destination": "/api/markdown?section=solutions&slug="
    },
    {
      "source": "/solutions/(.+)\\.md",
      "destination": "/api/markdown?section=solutions&slug=$1"
    },
    {
      "source": "/templates/(.+)\\.md",
      "destination": "/api/markdown?section=resources&slug=$1"
    },
    {
      "source": "/(.+)\\.md",
      "destination": "/api/markdown?section=docs&slug=$1"
    }
  ],
  "headers": [
    {
      "source": "/(docs|templates|solutions)(.*)",
      "headers": [
        { "key": "Link", "value": "</llms.txt>; rel=\"llms-txt\"" },
        { "key": "X-LLMs-Txt", "value": "/llms.txt" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
